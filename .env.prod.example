# Copy this to .env.prod for docker-compose.prod.yml
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/homework_ai
JWT_SECRET=change-this-to-a-long-random-secret
OPENAI_API_KEY=sk-your-openai-key-here
PORT=3001

# Also set these shell env vars (not in file) for docker-compose.prod.yml:
# MYSQL_ROOT_PASSWORD=strong-root-password
# MYSQL_USER=app
# MYSQL_PASSWORD=strong-app-password
